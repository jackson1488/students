{
  "name": "student-accounting-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:local": "expo start --lan",
    "start:local:clear": "expo start --lan -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "export:web:pages": "expo export --platform web && node scripts/prepare-pages.js",
    "export:web:pwa": "expo export --platform web && node scripts/setup-pwa.js",
    "build:android:arm64:apk": "eas build --platform android --profile android-arm64-apk",
    "build:android:arm64:apk:clear": "eas build --platform android --profile android-arm64-apk --clear-cache"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.5.3",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.29",
    "axios": "^1.13.0",
    "base-64": "^1.0.0",
    "expo": "~54.0.13",
    "expo-build-properties": "^55.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-localization": "~17.0.7",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.8",
    "i18n-js": "^4.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "eas-cli": "^18.4.0"
  }
}
